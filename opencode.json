{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "coder": {
      "description": "Implements tickets using test-first development",
      "mode": "primary",
      "temperature": 0.1,
      "steps": 50,
      "prompt": "{file:./.opencode/prompts/coder.md}",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "deny",
        "websearch": "deny",
        "webfetch": "deny",
        "serena_*": "allow",
        "gitnexus_*": "allow",
        "context7_*": "allow",
        "pullmd_*": "allow",
        "hindsight_*": "allow",
        "firecrawl_*": "allow"
      },
      "model": "opencode-go/qwen3.5-plus"
    },
    "reviewer": {
      "description": "Reviews pull requests for code quality and security",
      "mode": "primary",
      "temperature": 0.3,
      "steps": 50,
      "prompt": "{file:./.opencode/prompts/reviewer.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "edit": "deny",
        "task": "deny",
        "websearch": "deny",
        "webfetch": "deny",
        "ticket-read": "allow",
        "ticket-update": "allow",
        "ticket-comment": "allow",
        "serena_*": "allow",
        "gitnexus_*": "allow",
        "context7_*": "allow",
        "hindsight_*": "allow"
      },
      "model": "zai-coding-plan/glm-4.7"
    },
    "merger": {
      "description": "Verifies scope match and merges eligible pull requests",
      "mode": "primary",
      "temperature": 0.1,
      "steps": 50,
      "prompt": "{file:./.opencode/prompts/merger.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "edit": "deny",
        "task": "deny",
        "websearch": "deny",
        "webfetch": "deny",
        "ticket-read": "allow",
        "ticket-update": "allow",
        "ticket-comment": "allow",
        "ticket-list": "allow",
        "serena_*": "allow",
        "gitnexus_*": "allow",
        "context7_*": "allow",
        "hindsight_*": "allow"
      },
      "model": "zai-coding-plan/glm-4.7"
    },
    "decomposer": {
      "description": "Grills PRDs and decomposes them into well-specified tickets",
      "mode": "primary",
      "temperature": 0.5,
      "steps": 100,
      "prompt": "{file:./.opencode/prompts/decomposer.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "edit": "deny",
        "task": "deny",
        "websearch": "deny",
        "webfetch": "deny",
        "serena_*": "allow",
        "gitnexus_*": "allow",
        "context7_*": "allow",
        "pullmd_*": "allow",
        "hindsight_*": "allow",
        "firecrawl_*": "allow"
      },
      "model": "zai-coding-plan/glm-5.1"
    }
  }
}
